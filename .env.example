# PostgreSQL — pg8000 driver (pure Python, works on any Python version)
DATABASE_URL=postgresql+pg8000://user:password@localhost:5432/urbancall

# ── Account 1: Worker Line ───────────────────────────────────────────────────
# Phone A (inbound) is attached to this account. Outbound job-offer calls
# originate from the same phone number.
AGENT_WORKER_INBOUND_ID=your_worker_inbound_agent_id
AGENT_WORKER_INBOUND_API_KEY=your_bolna_api_key_for_account_1
AGENT_WORKER_INBOUND_FROM_PHONE=+1XXXXXXXXXX

AGENT_WORKER_JOB_OFFER_ID=your_worker_job_offer_agent_id
AGENT_WORKER_JOB_OFFER_API_KEY=your_bolna_api_key_for_account_1

# ── Account 2: Customer Line ─────────────────────────────────────────────────
# Phone B (inbound) is attached to this account. Outbound pairing + feedback
# calls originate from the same phone number.
AGENT_CUSTOMER_INBOUND_ID=your_customer_inbound_agent_id
AGENT_CUSTOMER_INBOUND_API_KEY=your_bolna_api_key_for_account_2
AGENT_CUSTOMER_INBOUND_FROM_PHONE=+1XXXXXXXXXX

AGENT_CUSTOMER_PAIRING_ID=your_customer_pairing_agent_id
AGENT_CUSTOMER_PAIRING_API_KEY=your_bolna_api_key_for_account_2

AGENT_CUSTOMER_FEEDBACK_ID=your_customer_feedback_agent_id
AGENT_CUSTOMER_FEEDBACK_API_KEY=your_bolna_api_key_for_account_2

# Bolna (do not change)
BOLNA_BASE_URL=https://api.bolna.ai

# Job queue polling interval
JOB_POLL_INTERVAL_SECONDS=15
